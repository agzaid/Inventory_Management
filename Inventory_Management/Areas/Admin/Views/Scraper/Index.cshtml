@model List<Domain.Models.ProductVM>

<div class="page-wrapper">
    <div class="page-content">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 text-uppercase">🕷️ Market Price Scraper</h5>
            <button type="button" class="btn btn-warning px-4" onclick="scrapeAll()">
                <i class="bx bx-run"></i> Scrape All Products
            </button>
        </div>

        <div class="card radius-10">
            <div class="card-body">
                <div class="table-responsive">
                    <table id="scraperTable" class="table table-striped table-bordered align-middle">
                        <thead>
                            <tr>
                                <th>Product Name</th>
                                <th>System Price</th>
                                <th style="width: 30%;">Scraping URL</th>
                                <th>Other Shops Price</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr id="row-@item.Id">
                                    <td>
                                        <div class="fw-bold">@item.ProductName</div>
                                        <small class="text-muted">@item.ProductNameAr</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-light-primary text-primary w-100">
                                            @item.SellingPrice EGP
                                        </span>
                                    </td>
                                    <td>
                                        <form class="scrape-form">
                                            <input type="hidden" name="productId" value="@item.Id" />
                                            <div class="input-group input-group-sm">
                                                <input type="url" name="sourceUrl" class="form-control"
                                                       placeholder="Paste Carrefour/Amazon URL..."
                                                       value="@item.Barcode"> @* Assuming SourceUrl exists in VM *@
                                            </div>
                                        </form>
                                    </td>
                                    <td class="text-center">
                                        <h6 class="scraped-result mb-0 text-secondary">@item.OtherShopsPrice</h6>
                                    </td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-primary btn-scrape-single">
                                            <i class="bx bx-refresh"></i> Scrape
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            // Initialize DataTable if you want search/pagination
            const table = $('#scraperTable').DataTable({
                lengthChange: false,
                buttons: ['copy', 'excel', 'pdf', 'print']
            });

            // Handle Single Scrape Button
            $('.btn-scrape-single').on('click', function () {
                const $row = $(this).closest('tr');
                scrapeRow($row);
            });
        });

        // Async function to scrape a single row
        function scrapeRow($row) {
            return new Promise((resolve) => {
                const $btn = $row.find('.btn-scrape-single');
                const $resultCell = $row.find('.scraped-result');
                const sourceUrl = $row.find('input[name="sourceUrl"]').val();
                const productId = $row.find('input[name="productId"]').val();
                const originalHtml = $btn.html();

                if (!sourceUrl) {
                    $resultCell.html('<small class="text-danger">Missing URL</small>');
                    resolve();
                    return;
                }

                // Loading State
                $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');
                $resultCell.html('<div class="spinner-grow spinner-grow-sm text-primary"></div>');

                $.ajax({
                    url: '@Url.Action("TestScrape", "Scraper")',
                    type: 'GET',
                    data: { url: sourceUrl },
                    success: function (response) {
                        if (response.success) {
                            $resultCell.text(response.price + " " + response.currency)
                                       .removeClass("text-secondary")
                                       .addClass("text-success fw-bold");
                        } else {
                            $resultCell.html('<small class="text-danger">Failed</small>');
                            console.error("Scrape Error:", response.error);
                        }
                    },
                    error: function () {
                        $resultCell.html('<small class="text-danger">Server Error</small>');
                    },
                    complete: function () {
                        $btn.prop('disabled', false).html(originalHtml);
                        resolve();
                    }
                });
            });
        }

        // Bulk Scrape All rows sequentially
        async function scrapeAll() {
            const $rows = $('.scrape-form').closest('tr');

            if (!confirm(`Are you sure you want to scrape ${$rows.length} items?`)) return;

            for (let i = 0; i < $rows.length; i++) {
                await scrapeRow($($rows[i]));
                // Optional delay to be nice to the target server
                await new Promise(r => setTimeout(r, 500));
            }

            alert("Bulk scraping process finished.");
        }
    </script>
}